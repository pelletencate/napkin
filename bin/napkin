#!/usr/bin/env sh
# napkin serve        <session-dir>  — launch daemon; prints NAPKIN_READY; exits 0
# napkin connect      <session-dir>  — block for one annotation; print JSON; exit 0/1/2
# napkin stop         <session-dir>  — graceful shutdown via POST /stop
# napkin export-human <session-dir>  — bundle proposal.html + kit → napkin.html

set -e

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if command -v bun >/dev/null 2>&1; then
  RUNTIME=bun
  RUN_ARGS=""
elif command -v node >/dev/null 2>&1; then
  RUNTIME=node
  RUN_ARGS="--experimental-strip-types"
else
  echo "ERROR: This skill needs bun (preferred) or node." >&2
  echo "  Install bun:  curl -fsSL https://bun.sh/install | bash" >&2
  echo "  Install Node: https://nodejs.org" >&2
  exit 2
fi

CMD="${1:-}"
SESSION_DIR="${2:-./.napkin-session}"

case "$CMD" in
  serve)
    mkdir -p "$SESSION_DIR"
    # Kit assets are served from the skill's assets/ dir at /napkin-kit.{css,js}
    # — no need to stage them in the session dir.
    exec $RUNTIME $RUN_ARGS "$SKILL_DIR/server/serve.ts" serve "$SESSION_DIR"
    ;;

  connect)
    exec $RUNTIME $RUN_ARGS "$SKILL_DIR/server/serve.ts" connect "$SESSION_DIR"
    ;;

  export-human)
    # Optional third arg: output path (defaults to ./docs/human/napkin.html)
    exec $RUNTIME $RUN_ARGS "$SKILL_DIR/server/export-human.ts" "$SESSION_DIR" "${3:-}"
    ;;

  stop)
    SERVER_JSON="$SESSION_DIR/server.json"
    if [ ! -f "$SERVER_JSON" ]; then
      echo "No server.json found at $SERVER_JSON" >&2
      exit 1
    fi
    # Extract port and token with grep/sed (no runtime dependency)
    PORT=$(grep -o '"port":[0-9]*' "$SERVER_JSON" | grep -o '[0-9]*')
    TOKEN=$(grep -o '"token":"[^"]*"' "$SERVER_JSON" | sed 's/"token":"//;s/"//')
    if [ -z "$PORT" ] || [ -z "$TOKEN" ]; then
      echo "Could not parse server.json" >&2
      exit 1
    fi
    curl -s -X POST -H "X-NK-Token: $TOKEN" "http://127.0.0.1:$PORT/stop" > /dev/null
    echo "Stopped napkin server on port $PORT"
    ;;

  *)
    echo "Usage: napkin serve        [session-dir]" >&2
    echo "       napkin connect      [session-dir]" >&2
    echo "       napkin stop         [session-dir]" >&2
    echo "       napkin export-human [session-dir] [out-path]   # defaults to ./docs/human/napkin.html" >&2
    exit 1
    ;;
esac
